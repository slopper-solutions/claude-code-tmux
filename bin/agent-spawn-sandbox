#!/bin/sh
# agent-spawn-sandbox: launch an LLM-CLI harness filesystem-restricted to <dir>
# via bubblewrap. Window decorated as "[<host>][<harness>] <name>".
#
# Usage: agent-spawn-sandbox [--rc|--no-rc] [--yolo|--safe] [--harness=<name>]
#                            <dir> [<name>] [<prompt>]
#
# Defaults: harness=claude, --rc/--yolo from ~/.config/remote-claude/config.env.
# Per-harness behavior comes from harnesses.d/<harness>.conf — only harnesses
# with SANDBOX_OK=1 and STATUS=stable are accepted.
set -e

SESSION="${REMOTE_CLAUDE_SESSION:-main}"
CONFIG_FILE="$HOME/.config/remote-claude/config.env"
HN="$(uname -n)"
HN="${HN%%.*}"
[ -n "$HN" ] || HN="host"

HARNESSES_DIR=""
for cand in "$REMOTE_CLAUDE_HARNESSES_DIR" "$HOME/.config/remote-claude/harnesses.d"; do
	[ -n "$cand" ] && [ -d "$cand" ] && { HARNESSES_DIR="$cand"; break; }
done
if [ -z "$HARNESSES_DIR" ]; then
	echo "agent-spawn-sandbox: harnesses.d not found (looked at \$REMOTE_CLAUDE_HARNESSES_DIR and ~/.config/remote-claude/harnesses.d)" >&2
	exit 1
fi

REMOTE_CONTROL=1
SKIP_PERMISSIONS=1
[ -f "$CONFIG_FILE" ] && . "$CONFIG_FILE"

HARNESS=claude

while [ $# -gt 0 ]; do
	case "$1" in
		--rc)         REMOTE_CONTROL=1; shift ;;
		--no-rc)      REMOTE_CONTROL=0; shift ;;
		--yolo)       SKIP_PERMISSIONS=1; shift ;;
		--safe)       SKIP_PERMISSIONS=0; shift ;;
		--harness=*)  HARNESS="${1#--harness=}"; shift ;;
		--harness)    HARNESS="$2"; shift 2 ;;
		--)           shift; break ;;
		-*)           echo "agent-spawn-sandbox: unknown flag: $1" >&2; exit 2 ;;
		*)            break ;;
	esac
done

if [ $# -lt 1 ]; then
	echo "usage: agent-spawn-sandbox [--rc|--no-rc] [--yolo|--safe] [--harness=<name>] <dir> [<name>] [<prompt>]" >&2
	exit 2
fi

HARNESS_FILE="$HARNESSES_DIR/$HARNESS.conf"
if [ ! -f "$HARNESS_FILE" ]; then
	echo "agent-spawn-sandbox: unknown harness '$HARNESS' (no $HARNESS_FILE)" >&2
	registered=""
	for f in "$HARNESSES_DIR"/*.conf; do
		[ -f "$f" ] || continue
		n=${f##*/}; n=${n%.conf}
		registered="$registered $n"
	done
	echo "  registered:${registered:- (none)}" >&2
	exit 2
fi
unset BINARY RC_FLAG RC_TAKES_NAME YOLO_FLAG SANDBOX_OK STATUS
. "$HARNESS_FILE"
if [ -z "${STATUS:-}" ] || [ -z "${BINARY:-}" ]; then
	echo "agent-spawn-sandbox: $HARNESS_FILE missing required field BINARY or STATUS" >&2
	exit 2
fi
if [ "$STATUS" != "stable" ]; then
	echo "agent-spawn-sandbox: harness '$HARNESS' is registered as '$STATUS'." >&2
	echo "  Adapter not yet wired — refusing to spawn." >&2
	exit 1
fi
if [ "${SANDBOX_OK:-0}" != "1" ]; then
	echo "agent-spawn-sandbox: harness '$HARNESS' is marked SANDBOX_OK=0." >&2
	echo "  Use agent-spawn (unsandboxed) or wire bwrap support and flip the flag." >&2
	exit 1
fi

DIR="$1"
RAW_NAME="${2:-$(claude-random-name 2>/dev/null || echo "$HARNESS-$(date +%s)")}"
NAME="[$HN][$HARNESS] $RAW_NAME"
PROMPT="$3"

if ! command -v bwrap >/dev/null 2>&1; then
	echo "bwrap not installed. On Debian/Ubuntu: sudo apt-get install bubblewrap" >&2
	exit 1
fi

if [ -x "$HOME/.local/bin/$BINARY" ]; then
	BIN_PATH="$HOME/.local/bin/$BINARY"
elif command -v "$BINARY" >/dev/null 2>&1; then
	BIN_PATH="$(command -v "$BINARY")"
else
	echo "agent-spawn-sandbox: binary '$BINARY' for harness '$HARNESS' not found on PATH" >&2
	exit 1
fi

mkdir -p "$DIR"
DIR="$(cd "$DIR" && pwd)"

mkdir -p "$HOME/.config/claude" "$HOME/.claude" "$HOME/.cache/claude"

# Build claude-invocation portion. Per-call flags are interpolated in; $NAME is
# single-quoted so spaces survive the sh -c handoff inside tmux new-window.
RUN_PART="'$BIN_PATH'"
if [ "$REMOTE_CONTROL" = "1" ] && [ -n "$RC_FLAG" ]; then
	if [ "$RC_TAKES_NAME" = "1" ]; then
		RUN_PART="$RUN_PART $RC_FLAG '$NAME'"
	else
		RUN_PART="$RUN_PART $RC_FLAG"
	fi
fi
[ "$SKIP_PERMISSIONS" = "1" ] && [ -n "$YOLO_FLAG" ] && RUN_PART="$RUN_PART $YOLO_FLAG"

# Sandbox layout: / read-only, fresh /tmp/dev/proc, $DIR + Claude state dirs
# read-write. Network is shared so --rc / OAuth still work.
CMD="bwrap \
	--ro-bind / / \
	--tmpfs /tmp \
	--dev /dev \
	--proc /proc \
	--bind '$HOME/.config/claude' '$HOME/.config/claude' \
	--bind '$HOME/.claude' '$HOME/.claude' \
	--bind-try '$HOME/.cache/claude' '$HOME/.cache/claude' \
	--bind '$DIR' '$DIR' \
	--chdir '$DIR' \
	--die-with-parent \
	$RUN_PART"

tmux has-session -t "$SESSION" 2>/dev/null || tmux new-session -d -s "$SESSION"
tmux new-window -t "$SESSION" -n "$NAME" "$CMD"

# Auto-accept Claude Code's workspace trust dialog. Sandbox adds latency so
# wait slightly longer. Harmless on harnesses that don't show one.
sleep 3
tmux send-keys -t "$SESSION:=$NAME" Enter

if [ -n "$PROMPT" ]; then
	sleep 1
	tmux send-keys -l -t "$SESSION:=$NAME" "$PROMPT"
	sleep 0.3
	tmux send-keys -t "$SESSION:=$NAME" Enter
fi

echo "$SESSION:=$NAME"
