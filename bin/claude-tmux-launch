#!/bin/sh
# Launch the persistent `main` tmux session running Claude. Decorates the
# window/RC name with the short hostname so sessions from multiple VPS hosts
# stay distinguishable in the Claude mobile app.
#
# Invoked by claude-tmux.service. Kept as a standalone script (rather than an
# inline sh -c in the unit) to avoid systemd's specifier/escaping rules
# clashing with shell parameter expansion like ${HN%%.*}.
#
# Reads ~/.config/remote-claude/config.env if present. Defaults keep existing
# behaviour (both flags on) so upgrading without a config file is a no-op.
set -e

CLAUDE_BIN="$HOME/.local/bin/claude"
CONFIG_FILE="$HOME/.config/remote-claude/config.env"

REMOTE_CONTROL=1
SKIP_PERMISSIONS=1
[ -f "$CONFIG_FILE" ] && . "$CONFIG_FILE"

HN=$(uname -n)
HN=${HN%%.*}
[ -n "$HN" ] || HN="host"

NAME="[$HN] main"

set -- "$CLAUDE_BIN"
[ "$REMOTE_CONTROL" = "1" ] && set -- "$@" --rc "$NAME"
[ "$SKIP_PERMISSIONS" = "1" ] && set -- "$@" --dangerously-skip-permissions

exec tmux new-session -d -s main -n "$NAME" "$@"
