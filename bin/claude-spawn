#!/bin/sh
# DEPRECATED: forwards to agent-spawn --harness=claude.
# See bin/agent-spawn (canonical) and skills/spawn-agent/SKILL.md.
# Will be removed in a future release. Migrate to 'agent-spawn' (claude is the
# default harness, so flags and positional args are unchanged).
# Note: window naming changed to [<host>][claude] <slug> — older [<host>] <slug>
# windows from prior installs still work via the agent-* readers.
set -e
echo "claude-spawn: DEPRECATED — use 'agent-spawn' instead." >&2
exec agent-spawn --harness=claude "$@"
