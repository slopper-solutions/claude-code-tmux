#!/bin/sh
# agent-peek: print the current pane contents of an LLM-driven tmux window.
# Harness-agnostic — the pane is a TTY and capture-pane returns whatever's
# rendered, regardless of which harness is running.
#
# Usage: agent-peek [-n <lines>] <window>
#   -n <lines> extends capture upward into tmux scrollback by that many lines.
set -e

SESSION="main"
LINES=""
HN="$(uname -n)"
HN="${HN%%.*}"
[ -n "$HN" ] || HN="host"

while [ $# -gt 0 ]; do
	case "$1" in
		-n)   LINES="$2"; shift 2 ;;
		-n*)  LINES="${1#-n}"; shift ;;
		--)   shift; break ;;
		-*)   echo "agent-peek: unknown flag: $1" >&2; exit 2 ;;
		*)    break ;;
	esac
done

if [ $# -lt 1 ]; then
	echo "usage: agent-peek [-n <lines>] <window>" >&2
	echo "  Prints pane contents of main:<window>." >&2
	echo "  Bare names are decorated to '[<host>][claude] <slug>'. Pass the full" >&2
	echo "  '[host][harness] slug' form for foreign hosts or non-claude harnesses." >&2
	echo "  -n <lines> extends capture into scrollback above the visible region." >&2
	exit 2
fi

WIN="${1#=}"
case "$WIN" in
	\[*\]*) ;;
	*)      WIN="[$HN][claude] $WIN" ;;
esac

if [ -n "$LINES" ]; then
	tmux capture-pane -p -S "-$LINES" -t "$SESSION:=$WIN"
else
	tmux capture-pane -p -t "$SESSION:=$WIN"
fi
