#!/bin/sh
# Launch the persistent `main` tmux session running the bootstrap agent
# (Claude Code in Phase 1). Decorates the window/RC name with the short
# hostname so sessions from multiple VPS hosts stay distinguishable in the
# Claude mobile app.
#
# Invoked by agent-tmux.service. Kept as a standalone script (rather than an
# inline sh -c in the unit) to avoid systemd's specifier/escaping rules
# clashing with shell parameter expansion like ${HN%%.*}.
#
# Reads ~/.config/agents/config.env if present. Defaults keep existing
# behaviour (both flags on) so upgrading without a config file is a no-op.
set -e

CLAUDE_BIN="$HOME/.local/bin/claude"
CONFIG_FILE="$HOME/.config/agents/config.env"

REMOTE_CONTROL=1
SKIP_PERMISSIONS=1
[ -f "$CONFIG_FILE" ] && . "$CONFIG_FILE"

HN=$(uname -n)
HN=${HN%%.*}
[ -n "$HN" ] || HN="host"

# Window name follows the harness-tagged convention: [<host>][<harness>] <slug>.
# This script bootstraps the foundational Claude Code instance, so the harness
# tag is always 'claude'. Other harnesses get spawned later via agent-spawn.
NAME="[$HN][claude] main"

set -- "$CLAUDE_BIN"
[ "$REMOTE_CONTROL" = "1" ] && set -- "$@" --rc "$NAME"
[ "$SKIP_PERMISSIONS" = "1" ] && set -- "$@" --dangerously-skip-permissions

tmux new-session -d -s main -n "$NAME" "$@"

# Auto-accept Claude Code's workspace trust dialog. No config mechanism
# exists for pre-trusting directories (issue anthropics/claude-code#29285),
# so the only option from a headless context is to blind-send Enter after
# the session is up. Harmless if the dialog isn't shown — at Claude's chat
# prompt an empty submit is a no-op.
sleep 2
tmux send-keys -t "main:=$NAME" Enter
