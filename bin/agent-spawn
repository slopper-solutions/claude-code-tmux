#!/bin/sh
# agent-spawn: launch an LLM-CLI harness in a named tmux window inside the
# persistent `main` session. Window decorated as "[<host>][<harness>] <name>"
# so windows from multiple hosts and harnesses stay distinguishable.
#
# Usage: agent-spawn [--rc|--no-rc] [--yolo|--safe] [--harness=<name>] [<name>] [<prompt>]
#
# Defaults: harness=claude, --rc/--yolo from ~/.config/remote-claude/config.env
# (REMOTE_CONTROL, SKIP_PERMISSIONS); both on if file missing. Per-call flags win.
#
# Per-harness behavior comes from harnesses.d/<harness>.conf, looked up in:
#   $REMOTE_CLAUDE_HARNESSES_DIR (override), or
#   ~/.config/remote-claude/harnesses.d/
set -e

SESSION="${REMOTE_CLAUDE_SESSION:-main}"
CONFIG_FILE="$HOME/.config/remote-claude/config.env"
HN="$(uname -n)"
HN="${HN%%.*}"
[ -n "$HN" ] || HN="host"

HARNESSES_DIR=""
for cand in "$REMOTE_CLAUDE_HARNESSES_DIR" "$HOME/.config/remote-claude/harnesses.d"; do
	[ -n "$cand" ] && [ -d "$cand" ] && { HARNESSES_DIR="$cand"; break; }
done
if [ -z "$HARNESSES_DIR" ]; then
	echo "agent-spawn: harnesses.d not found (looked at \$REMOTE_CLAUDE_HARNESSES_DIR and ~/.config/remote-claude/harnesses.d)" >&2
	exit 1
fi

REMOTE_CONTROL=1
SKIP_PERMISSIONS=1
[ -f "$CONFIG_FILE" ] && . "$CONFIG_FILE"

HARNESS=claude

while [ $# -gt 0 ]; do
	case "$1" in
		--rc)         REMOTE_CONTROL=1; shift ;;
		--no-rc)      REMOTE_CONTROL=0; shift ;;
		--yolo)       SKIP_PERMISSIONS=1; shift ;;
		--safe)       SKIP_PERMISSIONS=0; shift ;;
		--harness=*)  HARNESS="${1#--harness=}"; shift ;;
		--harness)    HARNESS="$2"; shift 2 ;;
		--)           shift; break ;;
		-*)           echo "agent-spawn: unknown flag: $1" >&2; exit 2 ;;
		*)            break ;;
	esac
done

HARNESS_FILE="$HARNESSES_DIR/$HARNESS.conf"
if [ ! -f "$HARNESS_FILE" ]; then
	echo "agent-spawn: unknown harness '$HARNESS' (no $HARNESS_FILE)" >&2
	registered=""
	for f in "$HARNESSES_DIR"/*.conf; do
		[ -f "$f" ] || continue
		n=${f##*/}; n=${n%.conf}
		registered="$registered $n"
	done
	echo "  registered:${registered:- (none)}" >&2
	exit 2
fi
unset BINARY RC_FLAG RC_TAKES_NAME YOLO_FLAG SANDBOX_OK STATUS
. "$HARNESS_FILE"
if [ -z "${STATUS:-}" ] || [ -z "${BINARY:-}" ]; then
	echo "agent-spawn: $HARNESS_FILE missing required field BINARY or STATUS" >&2
	exit 2
fi
if [ "$STATUS" != "stable" ]; then
	echo "agent-spawn: harness '$HARNESS' is registered as '$STATUS'." >&2
	echo "  Adapter for paste/idle behavior is not wired yet — refusing to spawn." >&2
	echo "  See $HARNESS_FILE for what's needed to flip it to 'stable'." >&2
	exit 1
fi

if [ -x "$HOME/.local/bin/$BINARY" ]; then
	BIN_PATH="$HOME/.local/bin/$BINARY"
elif command -v "$BINARY" >/dev/null 2>&1; then
	BIN_PATH="$(command -v "$BINARY")"
else
	echo "agent-spawn: binary '$BINARY' for harness '$HARNESS' not found on PATH" >&2
	exit 1
fi

RAW_NAME="${1:-$(claude-random-name 2>/dev/null || echo "$HARNESS-$(date +%s)")}"
NAME="[$HN][$HARNESS] $RAW_NAME"
PROMPT="$2"

tmux has-session -t "$SESSION" 2>/dev/null || tmux new-session -d -s "$SESSION"

set -- "$BIN_PATH"
if [ "$REMOTE_CONTROL" = "1" ] && [ -n "$RC_FLAG" ]; then
	if [ "$RC_TAKES_NAME" = "1" ]; then
		set -- "$@" "$RC_FLAG" "$NAME"
	else
		set -- "$@" "$RC_FLAG"
	fi
fi
[ "$SKIP_PERMISSIONS" = "1" ] && [ -n "$YOLO_FLAG" ] && set -- "$@" "$YOLO_FLAG"

tmux new-window -t "$SESSION" -n "$NAME" "$@"

# Auto-accept Claude Code's workspace trust dialog. No-op on harnesses that
# don't show one (Enter at an empty chat prompt).
sleep 2
tmux send-keys -t "$SESSION:=$NAME" Enter

if [ -n "$PROMPT" ]; then
	sleep 1
	# Text and Enter sent separately: Claude Code's Ink TUI treats batched
	# text+Enter as a paste (which doesn't auto-submit). The intervening
	# sleep lets the paste window close so Enter is read as submit. This is
	# Claude-specific behavior; Phase 2 per-harness adapters will dispatch.
	tmux send-keys -l -t "$SESSION:=$NAME" "$PROMPT"
	sleep 0.3
	tmux send-keys -t "$SESSION:=$NAME" Enter
fi

echo "$SESSION:=$NAME"
