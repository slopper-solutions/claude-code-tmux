#!/bin/sh
# DEPRECATED: forwards to agent-list. See bin/agent-list (canonical).
# Note: agent-list output adds a harness column, so any scripts parsing the
# old "main\t<window>" / "helper\t<window>" two-column form need updating.
set -e
echo "claude-list: DEPRECATED — use 'agent-list' instead. Output format adds a harness column." >&2
exec agent-list "$@"
