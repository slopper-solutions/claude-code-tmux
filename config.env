# Remote-Claude config — deployed to ~/.config/remote-claude/config.env
#
# Sourced by claude-tmux-launch and claude-spawn. Also loaded by
# claude-tmux.service via EnvironmentFile= so the main session picks up
# changes on `systemctl --user restart claude-tmux`.
#
# Format is strict KEY=VALUE (no shell expansion, no `export`) — systemd's
# EnvironmentFile reader does not run a shell.
#
# All values optional. Missing file or missing var falls back to the defaults
# baked into the scripts (currently both flags on).

# Enable Claude Code Remote Control (--rc) so sessions are reachable from the
# Claude mobile app. 1 = on, 0 = off.
REMOTE_CONTROL=1

# Enable --dangerously-skip-permissions. 1 = on, 0 = off.
# Turn off for prompt-by-prompt permission gating.
SKIP_PERMISSIONS=1
